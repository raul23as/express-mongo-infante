<%- include('partials/head') %>
<style>
  .page-content { padding:36px 0 60px; }
  .banner { background:linear-gradient(135deg,#b71c1c,#c62828);border-radius:16px;
    color:#fff;padding:32px 36px;margin-bottom:28px; }
  .banner h4 { font-weight:700;margin:0 0 6px; }
  .stat-num  { font-size:2.2rem;font-weight:700;color:#1a237e; }
  .stat-lbl  { color:#9e9e9e;font-size:.85rem; }
  .badge-role{ display:inline-block;padding:2px 10px;border-radius:20px;font-size:.72rem;font-weight:600; }
  .role-admin{ background:#1a237e;color:#fff; }
  .role-user { background:#e8eaf6;color:#1a237e; }
  table.striped>tbody>tr:nth-child(odd){ background:#f5f7ff; }
  .modal { border-radius:16px;max-width:500px!important; }
  .mrow  { display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #eee; }
  .mlbl  { color:#9e9e9e;font-size:.82rem; }
  .mval  { font-weight:600;font-size:.9rem; }
</style>
<%- include('partials/navbar') %>
<div class="container page-content">
  <div class="banner">
    <h4>🛡️ Panel de Administración</h4>
    <p>Gestiona todos los usuarios registrados.</p>
  </div>
  <div class="row">
    <div class="col s12 m4"><div class="card" style="border-radius:14px;text-align:center;">
      <div class="card-content">
        <div class="stat-num" id="totalUsers">—</div>
        <div class="stat-lbl">Total usuarios</div>
      </div>
    </div></div>
    <div class="col s12 m4"><div class="card" style="border-radius:14px;text-align:center;">
      <div class="card-content">
        <div class="stat-num" id="totalAdmins">—</div>
        <div class="stat-lbl">Administradores</div>
      </div>
    </div></div>
    <div class="col s12 m4"><div class="card" style="border-radius:14px;text-align:center;">
      <div class="card-content">
        <div class="stat-num" id="totalRegular">—</div>
        <div class="stat-lbl">Usuarios regulares</div>
      </div>
    </div></div>
  </div>
  <div class="card" style="border-radius:14px;">
    <div class="card-content">
      <span class="card-title" style="font-weight:700;color:#1a237e;">
        <i class="material-icons left">people</i>Listado de usuarios
      </span>
      <div class="input-field">
        <i class="material-icons prefix">search</i>
        <input id="searchInput" type="text"/>
        <label for="searchInput">Buscar por nombre o email</label>
      </div>
      <div class="responsive-table">
        <table class="striped highlight" id="usersTable">
          <thead><tr>
            <th>#</th><th>Nombre completo</th><th>Email</th>
            <th>Teléfono</th><th>Roles</th><th>Registro</th><th>Ver</th>
          </tr></thead>
          <tbody id="usersBody">
            <tr><td colspan="7" style="text-align:center;padding:30px;">
              <div class="preloader-wrapper small active">
                <div class="spinner-layer spinner-blue-only">
                  <div class="circle-clipper left"><div class="circle"></div></div>
                  <div class="gap-patch"><div class="circle"></div></div>
                  <div class="circle-clipper right"><div class="circle"></div></div>
                </div>
              </div>
            </td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="userModal" class="modal">
  <div class="modal-content">
    <h5 id="modalTitle" style="font-weight:700;color:#1a237e;"></h5>
    <div id="modalBody"></div>
  </div>
  <div class="modal-footer"><a href="#!" class="modal-close btn-flat">Cerrar</a></div>
</div>

<%- include('partials/footer') %>
<script>
if(!Auth.requireRole('admin')) throw new Error();

let allUsers = [];

async function loadUsers(){
  const res = await Auth.apiFetch('/api/users');
  if(!res||!res.ok) return;
  allUsers = await res.json();
  document.getElementById('totalUsers').textContent   = allUsers.length;
  document.getElementById('totalAdmins').textContent  = allUsers.filter(u=>u.roles.includes('admin')).length;
  document.getElementById('totalRegular').textContent = allUsers.filter(u=>!u.roles.includes('admin')).length;
  renderTable(allUsers);
}

function renderTable(users){
  const tbody = document.getElementById('usersBody');
  if(!users.length){
    tbody.innerHTML=`<tr><td colspan="7" style="text-align:center;color:#9e9e9e;padding:30px;">Sin resultados</td></tr>`;
    return;
  }
  tbody.innerHTML = users.map((u,i)=>`
    <tr>
      <td>${i+1}</td>
      <td><strong>${u.name} ${u.lastName||''}</strong></td>
      <td>${u.email}</td>
      <td>${u.phoneNumber||'—'}</td>
      <td>${(u.roles||[]).map(r=>`<span class="badge-role role-${r}">${r}</span>`).join(' ')}</td>
      <td>${u.createdAt ? new Date(u.createdAt).toLocaleDateString('es-PE') : '—'}</td>
      <td>
        <button class="btn btn-small waves-effect waves-light tooltipped"
          data-tooltip="Ver detalle" onclick="showUser('${u._id}')">
          <i class="material-icons">visibility</i>
        </button>
      </td>
    </tr>`).join('');
  M.Tooltip.init(document.querySelectorAll('.tooltipped'));
}

async function showUser(id){
  const res = await Auth.apiFetch(`/api/users/${id}`);
  if(!res||!res.ok) return;
  const u = await res.json();
  document.getElementById('modalTitle').textContent = `${u.name} ${u.lastName||''}`;
  const rows = [
    ['Email',            u.email],
    ['Teléfono',         u.phoneNumber||'—'],
    ['Nacimiento',       u.birthdate ? new Date(u.birthdate).toLocaleDateString('es-PE') : '—'],
    ['Edad',             u.age!=null ? `${u.age} años` : '—'],
    ['Dirección',        u.address||'—'],
    ['Roles',            (u.roles||[]).map(r=>`<span class="badge-role role-${r}">${r}</span>`).join(' ')],
    ['Registrado el',    u.createdAt ? new Date(u.createdAt).toLocaleString('es-PE') : '—'],
  ];
  document.getElementById('modalBody').innerHTML =
    rows.map(([l,v])=>`<div class="mrow"><span class="mlbl">${l}</span><span class="mval">${v}</span></div>`).join('');
  M.Modal.getInstance(document.getElementById('userModal')).open();
}

document.getElementById('searchInput').addEventListener('input', function(){
  const q = this.value.toLowerCase();
  renderTable(allUsers.filter(u =>
    (u.name+' '+(u.lastName||'')).toLowerCase().includes(q) || u.email.toLowerCase().includes(q)
  ));
});

loadUsers();
</script>
