<%- include('partials/head') %>
<style>
  .auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center;
    background:linear-gradient(135deg,#1a237e,#1565c0); padding:40px 16px; }
  .auth-card { width:100%; max-width:520px; border-radius:16px; padding:40px 36px; }
  .auth-btn  { width:100%; margin-top:10px; height:46px; font-size:1rem; }
  .auth-link { text-align:center; margin-top:16px; }
  .auth-link a { color:#1a237e; font-weight:600; }
  .pw-hint   { font-size:.78rem; color:#888; margin-top:-12px; margin-bottom:12px; padding-left:3rem; }
  #errBox    { display:none; }
</style>
<div class="auth-wrap">
  <div class="card auth-card z-depth-4">
    <div style="text-align:center;margin-bottom:8px;">
      <i class="material-icons" style="font-size:48px;color:#1a237e;">person_add</i>
    </div>
    <h5 style="text-align:center;font-weight:700;color:#1a237e;">Crear cuenta</h5>
    <p style="text-align:center;color:#757575;margin-bottom:20px;">Completa el formulario</p>

    <div id="errBox" class="card-panel red lighten-4 red-text text-darken-2">
      <i class="material-icons tiny">error</i> <span id="errTxt"></span>
    </div>

    <div class="row" style="margin-bottom:0">
      <div class="input-field col s12 m6">
        <i class="material-icons prefix">person</i>
        <input id="name" type="text"/>
        <label for="name">Nombre</label>
      </div>
      <div class="input-field col s12 m6">
        <i class="material-icons prefix">person_outline</i>
        <input id="lastName" type="text"/>
        <label for="lastName">Apellido</label>
      </div>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">email</i>
      <input id="email" type="email"/>
      <label for="email">Correo electrónico</label>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">phone</i>
      <input id="phoneNumber" type="tel"/>
      <label for="phoneNumber">Teléfono</label>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">cake</i>
      <input id="birthdate" type="date"/>
      <label for="birthdate" class="active">Fecha de nacimiento</label>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">lock</i>
      <input id="password" type="password"/>
      <label for="password">Contraseña</label>
    </div>
    <p class="pw-hint">Mín. 8 caracteres · 1 mayúscula · 1 dígito · 1 especial (# $ % &amp; * @)</p>

    <button class="btn waves-effect waves-light auth-btn" id="btnRegister">
      <i class="material-icons left">how_to_reg</i>Registrarse
    </button>
    <p class="auth-link">¿Ya tienes cuenta? <a href="/signIn">Inicia sesión</a></p>
  </div>
</div>
<%- include('partials/footer') %>
<script>
document.getElementById('btnRegister').addEventListener('click', async () => {
  const errBox = document.getElementById('errBox');
  const errTxt = document.getElementById('errTxt');
  errBox.style.display = 'none';

  const body = {
    name:        document.getElementById('name').value.trim(),
    lastName:    document.getElementById('lastName').value.trim(),
    email:       document.getElementById('email').value.trim(),
    phoneNumber: document.getElementById('phoneNumber').value.trim(),
    birthdate:   document.getElementById('birthdate').value,
    password:    document.getElementById('password').value,
  };

  if(Object.values(body).some(v => !v)){
    errTxt.textContent = 'Todos los campos son obligatorios.'; errBox.style.display='block'; return;
  }
  const pwRx = /^(?=.*[A-Z])(?=.*\d)(?=.*[#$%&*@]).{8,}$/;
  if(!pwRx.test(body.password)){
    errTxt.textContent = 'La contraseña no cumple los requisitos.'; errBox.style.display='block'; return;
  }

  const btn = document.getElementById('btnRegister');
  btn.disabled = true;
  try {
    const res  = await fetch('/api/auth/signUp', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if(!res.ok){ errTxt.textContent = data.message||'Error al registrarse.'; errBox.style.display='block'; return; }
    M.toast({ html:'✅ Cuenta creada. ¡Inicia sesión!', displayLength:2500 });
    setTimeout(() => window.location.href = '/signIn', 2600);
  } catch { errTxt.textContent='Error de conexión.'; errBox.style.display='block'; }
  finally   { btn.disabled = false; }
});
</script>
