<%- include('partials/head') %>
<style>
  .auth-wrap { min-height:100vh; display:flex; align-items:center; justify-content:center;
    background:linear-gradient(135deg,#1a237e,#1565c0); }
  .auth-card { width:100%; max-width:420px; border-radius:16px; padding:40px 36px; }
  .auth-btn  { width:100%; margin-top:12px; height:46px; font-size:1rem; }
  .auth-link { text-align:center; margin-top:16px; color:#555; }
  .auth-link a { color:#1a237e; font-weight:600; }
  #errBox { display:none; }
</style>
<div class="auth-wrap">
  <div class="card auth-card z-depth-4">
    <div style="text-align:center;margin-bottom:8px;">
      <i class="material-icons" style="font-size:48px;color:#1a237e;">lock_open</i>
    </div>
    <h5 style="text-align:center;font-weight:700;color:#1a237e;">Iniciar sesión</h5>
    <p style="text-align:center;color:#757575;margin-bottom:24px;">Bienvenido de vuelta</p>

    <div id="errBox" class="card-panel red lighten-4 red-text text-darken-2">
      <i class="material-icons tiny">error</i> <span id="errTxt"></span>
    </div>

    <div class="input-field">
      <i class="material-icons prefix">email</i>
      <input id="email" type="email"/>
      <label for="email">Correo electrónico</label>
    </div>
    <div class="input-field">
      <i class="material-icons prefix">lock</i>
      <input id="password" type="password"/>
      <label for="password">Contraseña</label>
    </div>

    <button class="btn waves-effect waves-light auth-btn" id="btnLogin">
      <i class="material-icons left">login</i>Entrar
    </button>
    <p class="auth-link">¿No tienes cuenta? <a href="/signUp">Regístrate</a></p>
  </div>
</div>
<%- include('partials/footer') %>
<script>
(function(){
  const t = sessionStorage.getItem('jwt_token');
  if(t && !Auth.isExpired(t)){
    const u = Auth.getUser();
    window.location.href = u?.roles?.includes('admin') ? '/dashboard/admin' : '/dashboard/user';
  }
})();

document.getElementById('btnLogin').addEventListener('click', async () => {
  const errBox = document.getElementById('errBox');
  const errTxt = document.getElementById('errTxt');
  errBox.style.display = 'none';

  const email    = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;
  if(!email || !password){ errTxt.textContent='Completa todos los campos.'; errBox.style.display='block'; return; }

  const btn = document.getElementById('btnLogin');
  btn.disabled = true;
  try {
    const res  = await fetch('/api/auth/signIn', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ email, password })
    });
    const data = await res.json();
    if(!res.ok){ errTxt.textContent = data.message || 'Credenciales incorrectas.'; errBox.style.display='block'; return; }

    Auth.save(data.token, data.user);
    window.location.href = data.user.roles?.includes('admin') ? '/dashboard/admin' : '/dashboard/user';
  } catch { errTxt.textContent='Error de conexión.'; errBox.style.display='block'; }
  finally   { btn.disabled = false; }
});
</script>
