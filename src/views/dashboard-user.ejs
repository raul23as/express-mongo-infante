<%- include('partials/head') %>
<style>
  .page-content { padding:36px 0 60px; }
  .banner { background:linear-gradient(135deg,#1a237e,#1565c0);border-radius:16px;
    color:#fff;padding:36px 40px;margin-bottom:28px; }
  .banner h4 { font-weight:700;margin:0 0 6px; }
  .lbl { color:#9e9e9e;font-size:.8rem;text-transform:uppercase;letter-spacing:1px; }
  .val { font-size:1rem;font-weight:600;color:#212121; }
</style>
<%- include('partials/navbar') %>
<div class="container page-content">
  <div class="banner">
    <h4>👋 Bienvenido, <span id="userName">—</span></h4>
    <p>Este es tu panel personal.</p>
  </div>
  <div class="row">
    <div class="col s12 m6 l4">
      <div class="card" style="border-radius:14px;">
        <div class="card-content">
          <span class="card-title" style="font-size:1rem;font-weight:700;">
            <i class="material-icons left" style="color:#1a237e;">person</i>Datos personales
          </span>
          <p class="lbl">Nombre completo</p><p class="val" id="fullName">—</p>
          <p class="lbl">Correo</p><p class="val" id="email">—</p>
          <p class="lbl">Teléfono</p><p class="val" id="phone">—</p>
        </div>
      </div>
    </div>
    <div class="col s12 m6 l4">
      <div class="card" style="border-radius:14px;">
        <div class="card-content">
          <span class="card-title" style="font-size:1rem;font-weight:700;">
            <i class="material-icons left" style="color:#1a237e;">cake</i>Más información
          </span>
          <p class="lbl">Fecha de nacimiento</p><p class="val" id="birthdate">—</p>
          <p class="lbl">Edad</p><p class="val" id="age">—</p>
          <p class="lbl">Dirección</p><p class="val" id="address">—</p>
        </div>
      </div>
    </div>
    <div class="col s12 m12 l4">
      <div class="card" style="border-radius:14px;">
        <div class="card-content">
          <span class="card-title" style="font-size:1rem;font-weight:700;">
            <i class="material-icons left" style="color:#1a237e;">verified_user</i>Cuenta
          </span>
          <p class="lbl">Roles</p><p class="val" id="roles">—</p>
          <p class="lbl">Miembro desde</p><p class="val" id="createdAt">—</p>
        </div>
        <div class="card-action">
          <a href="/profile" class="btn btn-small waves-effect waves-light">
            <i class="material-icons left">edit</i>Editar perfil
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
<script>
if(!Auth.requireAuth()) throw new Error();

Auth.apiFetch('/api/users/me').then(async res => {
  if(!res||!res.ok) return;
  const u = await res.json();
  document.getElementById('userName').textContent  = u.name;
  document.getElementById('fullName').textContent  = `${u.name} ${u.lastName}`;
  document.getElementById('email').textContent     = u.email;
  document.getElementById('phone').textContent     = u.phoneNumber||'—';
  document.getElementById('birthdate').textContent = u.birthdate ? new Date(u.birthdate).toLocaleDateString('es-PE') : '—';
  document.getElementById('age').textContent       = u.age!=null ? `${u.age} años` : '—';
  document.getElementById('address').textContent   = u.address||'—';
  document.getElementById('roles').textContent     = (u.roles||[]).join(', ');
  document.getElementById('createdAt').textContent = u.createdAt ? new Date(u.createdAt).toLocaleDateString('es-PE') : '—';
});
</script>
