<%- include('partials/head') %>
<style>
  .page-content { padding:36px 0 60px; }
  .avatar-wrap  { width:100px;height:100px;border-radius:50%;background:#e8eaf6;
    display:flex;align-items:center;justify-content:center;margin:0 auto 12px; }
  .badge-role   { display:inline-block;padding:2px 12px;border-radius:20px;font-size:.75rem;font-weight:600;margin:2px; }
  .role-admin   { background:#1a237e;color:#fff; }
  .role-user    { background:#e8eaf6;color:#1a237e; }
  #msgBox       { display:none; }
</style>
<%- include('partials/navbar') %>
<div class="container page-content">
  <div class="row">
    <div class="col s12 m4">
      <div class="card" style="padding:28px 16px;text-align:center;">
        <div class="avatar-wrap">
          <i class="material-icons" style="font-size:52px;color:#9fa8da;">person</i>
        </div>
        <h5 id="fullName" style="font-weight:700;margin:8px 0 4px;">—</h5>
        <p id="emailDisplay" style="color:#757575;margin:0 0 10px;">—</p>
        <div id="rolesDisplay"></div>
        <p style="color:#9e9e9e;font-size:.82rem;margin-top:12px;">
          Edad: <strong id="ageDisplay">—</strong> años<br>
          Miembro desde: <strong id="createdAt">—</strong>
        </p>
      </div>
    </div>
    <div class="col s12 m8">
      <div class="card" style="padding:28px 32px;">
        <h5 style="font-weight:700;color:#1a237e;margin-bottom:20px;">
          <i class="material-icons left">edit</i>Editar perfil
        </h5>
        <div id="msgBox" class="card-panel"><span id="msgTxt"></span></div>

        <div class="row" style="margin-bottom:0">
          <div class="input-field col s12 m6">
            <i class="material-icons prefix">person</i>
            <input id="name" type="text"/>
            <label for="name">Nombre</label>
          </div>
          <div class="input-field col s12 m6">
            <i class="material-icons prefix">person_outline</i>
            <input id="lastName" type="text"/>
            <label for="lastName">Apellido</label>
          </div>
        </div>
        <div class="input-field">
          <i class="material-icons prefix">phone</i>
          <input id="phoneNumber" type="tel"/>
          <label for="phoneNumber">Teléfono</label>
        </div>
        <div class="input-field">
          <i class="material-icons prefix">cake</i>
          <input id="birthdate" type="date"/>
          <label for="birthdate" class="active">Fecha de nacimiento</label>
        </div>
        <div class="input-field">
          <i class="material-icons prefix">home</i>
          <input id="address" type="text"/>
          <label for="address">Dirección</label>
        </div>
        <div class="input-field">
          <i class="material-icons prefix">image</i>
          <input id="url_profile" type="url"/>
          <label for="url_profile">URL foto de perfil</label>
        </div>
        <div class="divider" style="margin:16px 0;"></div>
        <p style="color:#9e9e9e;font-size:.83rem;">Deja en blanco para no cambiar la contraseña.</p>
        <div class="input-field">
          <i class="material-icons prefix">lock</i>
          <input id="password" type="password"/>
          <label for="password">Nueva contraseña</label>
        </div>
        <button class="btn waves-effect waves-light" id="btnSave">
          <i class="material-icons left">save</i>Guardar cambios
        </button>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
<script>
if(!Auth.requireAuth()) throw new Error();

async function loadProfile(){
  const res = await Auth.apiFetch('/api/users/me');
  if(!res||!res.ok) return;
  const u = await res.json();

  document.getElementById('fullName').textContent     = `${u.name} ${u.lastName}`;
  document.getElementById('emailDisplay').textContent = u.email;
  document.getElementById('ageDisplay').textContent   = u.age ?? '—';
  document.getElementById('createdAt').textContent    =
    u.createdAt ? new Date(u.createdAt).toLocaleDateString('es-PE') : '—';
  document.getElementById('rolesDisplay').innerHTML   =
    (u.roles||[]).map(r=>`<span class="badge-role role-${r}">${r.toUpperCase()}</span>`).join('');

  document.getElementById('name').value        = u.name||'';
  document.getElementById('lastName').value    = u.lastName||'';
  document.getElementById('phoneNumber').value = u.phoneNumber||'';
  document.getElementById('address').value     = u.address||'';
  document.getElementById('url_profile').value = u.url_profile||'';
  if(u.birthdate) document.getElementById('birthdate').value = u.birthdate.substring(0,10);
  M.updateTextFields();
}

document.getElementById('btnSave').addEventListener('click', async () => {
  const msgBox = document.getElementById('msgBox');
  const msgTxt = document.getElementById('msgTxt');
  msgBox.style.display = 'none';

  const body = {
    name:        document.getElementById('name').value.trim(),
    lastName:    document.getElementById('lastName').value.trim(),
    phoneNumber: document.getElementById('phoneNumber').value.trim(),
    birthdate:   document.getElementById('birthdate').value,
    address:     document.getElementById('address').value.trim(),
    url_profile: document.getElementById('url_profile').value.trim(),
  };
  const pw = document.getElementById('password').value;
  if(pw) body.password = pw;

  const btn = document.getElementById('btnSave');
  btn.disabled = true;
  const res  = await Auth.apiFetch('/api/users/me', { method:'PUT', body:JSON.stringify(body) });
  btn.disabled = false;
  if(!res) return;
  const data = await res.json();

  msgBox.style.display = 'block';
  if(res.ok){
    msgBox.className = 'card-panel green lighten-4 green-text text-darken-2';
    msgTxt.textContent = '✅ ' + data.message;
    loadProfile();
  } else {
    msgBox.className = 'card-panel red lighten-4 red-text text-darken-2';
    msgTxt.textContent = '❌ ' + (data.message||'Error al guardar.');
  }
  setTimeout(() => msgBox.style.display='none', 4000);
});

loadProfile();
</script>
